{
  "name": "@zakkster/lite-profiler",
  "version": "1.0.0",
  "description": "Zero-GC frame and per-phase profiler for game loops. performance.now() into power-of-two ring buffers, single-pass percentile stats, a bimodal frame-time classifier (GC-spike vs sustained throttle), and a shareable binary .litecap capture format with a reader. Engine-agnostic core; reactive layer ships separately.",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",

  "exports": {
    ".": {
      "types": "./index.d.ts",
      "node": "./index.js",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/",
    "README.md",
    "CHANGELOG.md",
    "llms.txt",
    "LICENSE.txt"
  ],
  "scripts": {
    "test": "node --test",
    "pack": "npm pack --dry-run",
    "bundle-check": "npx esbuild index.js --bundle --format=esm --external:@zakkster/* --outfile=test-bundle.js",
    "prepublishOnly": "npm run test && npm run bundle-check"
  },
  "keywords": [
    "profiler",
    "frame-time",
    "fps",
    "telemetry",
    "gc",
    "zero-gc",
    "percentile",
    "histogram",
    "game-loop",
    "performance",
    "ring-buffer",
    "oscilloscope",
    "lite-tools"
  ],
  "dependencies": {
    "@zakkster/lite-ring-buffer": "^1.0.1",
    "@zakkster/lite-stats-math": "^1.0.1",
    "@zakkster/lite-canvas-graph": "^1.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "license": "MIT",
  "author": "Zahary Shinikchiev <shinikchiev@yahoo.com>",
  "homepage": "https://github.com/PeshoVurtoleta/lite-profiler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeshoVurtoleta/lite-profiler.git"
  },
  "bugs": {
    "url": "https://github.com/PeshoVurtoleta/lite-profiler/issues",
    "email": "shinikchiev@yahoo.com"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/PeshoVurtoleta"
  },
  "sideEffects": false
}
